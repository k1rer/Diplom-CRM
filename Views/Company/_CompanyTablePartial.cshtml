@model Diplom_CRM.Models.View.CompanyIndexViewModel

@if (Model.Companies.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Название</th>
                    <th>Отрасль</th>
                    <th>Телефон</th>
                    <th>Город</th>
                    <th>Контактов</th>
                    <th>Создана</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var company in Model.Companies.Items)
                {
                    <tr>
                        <td>@company.Name</td>
                        <td>@(company.Industry ?? "—")</td>
                        <td>@(company.Phone ?? "—")</td>
                        <td>@(company.City ?? "—")</td>
                        <td>@company.ContactsCount</td>
                        <td>@company.CreatedAt.ToShortDateString()</td>
                        <td>
                            <a href="/Company/Details/@company.Id" class="btn btn-sm btn-outline-secondary">
                                Открыть
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Навигация по страницам">
        <ul class="pagination justify-content-center">
            @if (Model.Companies.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link"
                       hx-get="@Url.Action("Index", "Company", new { page = Model.Companies.Page - 1, searchTerm = Model.SearchTerm })"
                       hx-target="#companyTableContainer"
                       hx-push-url="true">
                        &laquo; Назад
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">&laquo; Назад</span></li>
            }

            @for (int i = 1; i <= Model.Companies.TotalPages; i++)
            {
                if (i == Model.Companies.Page)
                {
                    <li class="page-item active"><span class="page-link">@i</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           hx-get="@Url.Action("Index", "Company", new { page = i, searchTerm = Model.SearchTerm })"
                           hx-target="#companyTableContainer"
                           hx-push-url="true">@i</a>
                    </li>
                }
            }

            @if (Model.Companies.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link"
                       hx-get="@Url.Action("Index", "Company", new { page = Model.Companies.Page + 1, searchTerm = Model.SearchTerm })"
                       hx-target="#companyTableContainer"
                       hx-push-url="true">
                        Вперёд &raquo;
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Вперёд &raquo;</span></li>
            }
        </ul>
    </nav>
}
else
{
    <div class="alert alert-info">По вашему запросу компании не найдены.</div>
}