<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Diplom CRM</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <style>
            body {
                min-height: 100vh;
            }
            .sidebar {
                min-height: 100vh;
                width: 250px;
                position: fixed;
                top: 0;
                left: 0;
                padding-top: 20px;
                background-color: #212529;
            }
            .main-content {
                margin-left: 250px;
                padding: 20px;
            }
            .navbar-top {
                margin-left: 250px;
            }

            .htmx-indicator {
                display: none;
            }
            .htmx-request .htmx-indicator,
            .htmx-request.htmx-indicator {
                display: inline-block;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-light bg-light border-bottom navbar-top">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">CRM Панель</span>
            <div class="d-flex align-items-center">
                <span class="me-3">Иван Иванов (Менеджер)</span>
                <a href="/Account/Logout" class="btn btn-outline-secondary btn-sm">Выход</a>
            </div>
        </div>
    </nav>

    <aside class="sidebar d-flex flex-column text-white">
        <ul class="nav nav-pills flex-column mb-auto px-3">
            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active bg-primary" : "")"
                   href="/Dashboard/Index">
                    Дашборд
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Company" ? "active bg-primary" : "")"
                   href="/Company/Index">
                    Клиенты
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Deal" ? "active bg-primary" : "")"
                   href="/Deal/Index">
                    Воронка сделок
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Activity" ? "active bg-primary" : "")"
                   href="/Activity/Index">
                    Задачи
                </a>
            </li>
        </ul>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/htmx.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>